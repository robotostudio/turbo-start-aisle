# turbo-start-shopify required envs (boot fails without these)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333
SANITY_API_READ_TOKEN=your-read-token
SANITY_API_WRITE_TOKEN=your-write-token
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-token

# AI assistant envs (optional — chat returns 503 until both are set)
# AI_GATEWAY_API_KEY — get from https://vercel.com/dashboard/ai-gateway
# Only required for local dev. On Vercel deployments, OIDC auto-auths.
AI_GATEWAY_API_KEY=
SANITY_CONTEXT_MCP_URL=
